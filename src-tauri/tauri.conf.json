{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Viewer",
  "version": "0.1.0",
  "identifier": "com.igonajimi.mdviewer",
  "build": {
    "beforeDevCommand": "node tools/prepare-tauri-assets.mjs",
    "beforeBuildCommand": "node tools/prepare-tauri-assets.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Markdown Viewer",
        "url": "viewer.html",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
